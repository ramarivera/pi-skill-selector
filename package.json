{
  "name": "@ramarivera/pi-skill-selector",
  "version": "0.1.7",
  "description": "Pi extension that lets you type $ to fuzzy-pick skills and insert /skill:name into the prompt.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramarivera/pi-skill-selector.git"
  },
  "homepage": "https://github.com/ramarivera/pi-skill-selector#readme",
  "bugs": {
    "url": "https://github.com/ramarivera/pi-skill-selector/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "skills",
    "skill-selector",
    "autocomplete",
    "tui"
  ],
  "scripts": {
    "test": "bun test",
    "check": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "^24.0.0",
    "bun-types": "^1.3.9",
    "typescript": "^5.9.0"
  }
}
